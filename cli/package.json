{
  "name": "cli",
  "description": "deadrop CLI",
  "version": "0.2.4",
  "main": "dist/deadrop.js",
  "bin": {
    "deadrop": "./dist/deadrop.js"
  },
  "files": [
    "./dist/*",
    "./fonts/Standard.flf"
  ],
  "license": "MIT",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "prebuild": "sh ./scripts/prebuild.sh",
    "build": "node ./scripts/esbuild.js",
    "precompile": "cpx \"./node_modules/figlet/fonts/*.flf\" ./fonts",
    "compile": "bun run ./scripts/bun-build.ts",
    "postcompile": "rimraf fonts/",
    "postversion": "sh ./scripts/postversion.sh",
    "prepublishOnly": "sh ./scripts/prepublish.sh",
    "postpublish": "sh ./scripts/postpublish.sh",
    "release": "pnpm build && npm publish"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.2",
    "@inquirer/prompts": "^5.3.8",
    "chalk": "^5.2.0",
    "change-case": "^5.4.4",
    "commander": "^9.4.1",
    "cosmiconfig": "^9.0.0",
    "envfile": "^7.1.0",
    "figlet": "^1.5.2",
    "libsql": "^0.5.29",
    "mime": "^4.0.6",
    "node-datachannel": "^0.32.3",
    "open": "^10.1.0",
    "ora": "^6.1.2",
    "semver": "^7.5.4",
    "yaml": "^2.5.0"
  },
  "optionalDependencies": {
    "@libsql/darwin-arm64": "^0.5.29",
    "@libsql/darwin-x64": "^0.5.29",
    "@libsql/linux-arm64-gnu": "^0.5.29",
    "@libsql/linux-arm64-musl": "^0.5.29",
    "@libsql/linux-x64-gnu": "^0.5.29",
    "@libsql/linux-x64-musl": "^0.5.29",
    "@libsql/win32-x64-msvc": "^0.5.29"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/figlet": "^1.5.5",
    "bun": "^1.3.13",
    "cpx": "^1.5.0",
    "dotenv": "^16.0.3",
    "esbuild": "^0.16.15",
    "esbuild-plugin-environment": "^0.2.4",
    "replace": "^1.2.2",
    "rimraf": "^6.0.1"
  }
}
