{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "outDir": "dist",
    "noEmit": false,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "paths": {
      "@shared/*": ["../shared/*"],
      "@api/*": ["../worker/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "../worker", "../shared"]
}
