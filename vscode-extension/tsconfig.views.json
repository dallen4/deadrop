{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"],
      "@api/*": ["../worker/*"],
      "@ext/*": ["src/*"]
    }
  },
  "include": ["views/**/*.ts", "views/**/*.tsx"],
  "exclude": ["node_modules", "../worker", "../shared"]
}
