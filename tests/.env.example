# tests/.env — cross-platform e2e environment vars
# Copy to tests/.env and fill in values for local runs.
# In CI these are injected as repo secrets / workflow env.

# Deployed web app (trailing slash optional).
# Namespaced as XPLAT_ because Vitest/Vite reserves BASE_URL for its own base path.
XPLAT_BASE_URL=https://alpha.deadrop.io

# Deployed Cloudflare Worker
DEADROP_API_URL=https://api.deadrop.io

# Built CLI entry point (defaults to cli/dist/deadrop.js relative to repo root)
# CLI_ENTRY=

# Stable drop test token — persisted in Redis under `test_tkn`.
# READ ONLY: never seed or delete this value from tests.
DROP_TEST_TOKEN=

# Optional timeout overrides (ms)
# XPLAT_DROP_TIMEOUT=45000
# XPLAT_GRAB_TIMEOUT=45000
